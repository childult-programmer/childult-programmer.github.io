<ul class="card-text font-weight-light list-group list-group-flush">
  {% assign patents = data[1] | sort: 'date' | reverse %}

  {% for content in patents %}
    <li class="list-group-item">
      <div class="row">

        <!-- Date -->
        <div class="col-xs-2 cl-sm-2 col-md-2 text-center date-column">
          {% if content.date %}
            {% assign date = content.date | split: '-' | join: '.' %}
          {% else %}
            {% assign date = '' %}
          {% endif %}

          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  <span
                    class="badge font-weight-bold danger-color-dark text-uppercase align-middle"
                    style="min-width: 75px"
                  >
                    {{ date }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Content -->
        <div class="col-xs-10 cl-sm-10 col-md-10 mt-2 mt-md-0">

          <!-- Patent Title -->
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            {% if content.url %}
              <a href="{{ content.url }}">{{ content.name }}</a>
            {% else %}
              {{ content.name }}
            {% endif %}
          </h6>

          <!-- Patent Number -->
          {% if content.number %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
              Patent No. {{ content.number }}
            </h6>
          {% endif %}

          <!-- Patent Status -->
          {% if content.status %}
            <h6
              class="ml-1 ml-md-4"
              style="font-size: 0.95rem; font-style: italic"
            >
              {{ content.status }}
            </h6>
          {% endif %}

        </div>
      </div>
    </li>
  {% endfor %}
</ul>
